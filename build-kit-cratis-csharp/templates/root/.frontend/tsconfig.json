{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": false,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",
        /* Decorators */
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        /* Path aliases */
        "baseUrl": "..",
        "paths": {
            "Api/*": ["Features/*"]
        }
    },
    "include": [
        "../**/*.ts",
        "../**/*.tsx"
    ],
    "exclude": [
        "vite.config.ts",
        "../node_modules/**",
        "../wwwroot/**"
    ]
}
